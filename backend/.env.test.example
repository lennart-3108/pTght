# Test Instance Environment (.env.test)
# Copy to .env when deploying to test.matchleague.org

# Instance Type
INSTANCE_TYPE=test

# HTTP Server Port
PORT=5002

# Database
DB_PATH=sportsplatform-test.db

# CORS - Allow test domain
CORS_ORIGIN=https://test.matchleague.org

# JWT Secret (change in production!)
JWT_SECRET=your-jwt-secret-change-in-production

# Email Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@matchleague.org
MAIL_PASS=your-mail-password
MAIL_FROM=noreply@matchleague.org

# Mailer Verification (disabled for test)
MAILER_VERIFY=0

# Link Tests (disabled for test)
ENABLE_LINK_TESTS=0

# Base URL for email links
BASE_URL=https://test.matchleague.org

# Log Level
LOG_LEVEL=debug

# Feature Flags for Test Instance
ENABLE_LEAGUES=false
ENABLE_COMPETITIONS=false
ENABLE_BOOKINGS=false
ENABLE_VENUES=false

# Test Instance Warning
TEST_INSTANCE=true

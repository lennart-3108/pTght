# Production Instance Environment (.env.prod)
# Copy to .env when deploying to matchleague.org

# Instance Type
INSTANCE_TYPE=production

# HTTP Server Port
PORT=5003

# Database
DB_PATH=sportsplatform-prod.db

# CORS - Allow production domain
CORS_ORIGIN=https://matchleague.org

# JWT Secret (MUST be changed!)
JWT_SECRET=CHANGE-THIS-IN-PRODUCTION-USE-STRONG-RANDOM-STRING

# Email Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=true
MAIL_USER=noreply@matchleague.org
MAIL_PASS=CHANGE-THIS-IN-PRODUCTION
MAIL_FROM=Match League <noreply@matchleague.org>

# Mailer Verification (enabled for production)
MAILER_VERIFY=1

# Link Tests (enabled for production)
ENABLE_LINK_TESTS=1

# Base URL for email links
BASE_URL=https://matchleague.org

# Log Level
LOG_LEVEL=info

# Feature Flags (all disabled - landing page only)
ENABLE_LEAGUES=false
ENABLE_COMPETITIONS=false
ENABLE_BOOKINGS=false
ENABLE_VENUES=false
ENABLE_MATCHES=false

# Production Mode
NODE_ENV=production
TEST_INSTANCE=false

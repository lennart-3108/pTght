# AI Agent runtime config (copy values into your shell/CI secrets as needed)
ENABLE_INTERNAL_AI_AGENT=1
AGENT_API_BASE=http://127.0.0.1:5001/api
AGENT_INTERVAL_MS=300000
AGENT_COMMANDS=npm run check:all;npm run check:homepage-quality
# Set to 1 if you do not want an immediate run at server startup
AGENT_SKIP_BOOT_RUN=0
# Optional auth token if /api/tasks is protected
AGENT_TOKEN=
# Optional AI summarization
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Test Instance Environment (.env.test)
# Match League - test.matchleague.org

# Instance Type
INSTANCE_TYPE=test

# HTTP Server Port  
PORT=5002

# Database
DB_PATH=sportsplatform-test.db

# Frontend URL (for CORS)
FRONTEND_URL=https://test.matchleague.org

# CORS - Allow test domain
CORS_ORIGIN=https://test.matchleague.org

# JWT Secret (test instance - not critical)
JWT_SECRET=test-instance-jwt-secret-not-production

# Email Configuration (shared mailbox for all instances)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=info@matchleague.org
MAIL_PASS=Sursee.2026
MAIL_FROM=info@matchleague.org
MAIL_SUBJECT_PREFIX=TEST
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=info@matchleague.org
IMAP_PASS=Sursee.2026
IMAP_MAILBOX=Sent

# Mailer Verification (disabled for test)
MAILER_VERIFY=0

# Link Tests (disabled for test)
ENABLE_LINK_TESTS=0

# Base URL for email links and redirects
BASE_URL=https://test.matchleague.org

# Log Level
LOG_LEVEL=info

# Feature Flags - Control which features are enabled
# Test instance has only Tennis matches & chat
ENABLE_LEAGUES=false
ENABLE_COMPETITIONS=false
ENABLE_BOOKINGS=false
ENABLE_VENUES=false
ENABLE_MATCHES=true
ENABLE_CHAT=true

# Test Instance Marker (shown in UI)
TEST_INSTANCE=true

# Node environment
NODE_ENV=production

# Example development env for a separate dev instance
# Copy to backend/.env or use as reference. Do NOT commit real secrets.

# Server
PORT=5003

# Database (use a separate file for dev)
DB_PATH=database-dev.sqlite

# Mail (single mailbox strategy for dev/test/prod)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=info@matchleague.org
MAIL_PASS=REPLACE_WITH_PASSWORD
MAIL_DEBUG=1

# JWT secret (generate a new one for dev)
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# Optional
#CORS_ORIGIN=http://localhost:3000

# AI Test Agent (optional)
# AGENT_API_BASE=http://127.0.0.1:5001/api
# AGENT_TOKEN=
# AGENT_COMMANDS=npm run check:all;npm run check:homepage-quality;npm --prefix ../frontend run build
# AGENT_INTERVAL_MS=300000
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

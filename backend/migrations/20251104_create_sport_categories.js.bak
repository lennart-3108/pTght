          (SELECT id FROM sport_categories WHERE slug = 'racket'),
          (SELECT id FROM sports WHERE name = 'Tennis'),
          'Einzel',
          1,
          'Single',
          101
        UNION ALL
        SELECT 
          'Tennis Doppel',
          (SELECT id FROM sport_categories WHERE slug = 'racket'),
          (SELECT id FROM sports WHERE name = 'Tennis'),
          'Doppel',
          1,
          'Team',
          102
        UNION ALL
        SELECT 

        SELECT 
          'Fußball 11 vs 11',
          (SELECT id FROM sport_categories WHERE slug = 'ballsport'),
          (SELECT id FROM sports WHERE name = 'Fußball'),
          '11v11',
          1,
          'Team',
          201
        UNION ALL
        SELECT 
          'Fußball 7 vs 7',
          (SELECT id FROM sport_categories WHERE slug = 'ballsport'),
          (SELECT id FROM sports WHERE name = 'Fußball'),
          '7v7',
          1,
          'Team',
          202
